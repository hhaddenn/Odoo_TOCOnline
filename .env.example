# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=odoo_sync
POSTGRES_USER=sync_user
POSTGRES_PASSWORD=sync_pass
POSTGRES_HOST_PORT=5433
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgres://sync_user:sync_pass@db:5432/odoo_sync

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Odoo ──────────────────────────────────────────────────────────────────────
ODOO_BASE_URL=https://your-odoo.example.com
ODOO_DB=your_db
ODOO_USERNAME=admin
ODOO_PASSWORD=admin
ODOO_TIMEOUT=30
ODOO_MAX_RETRIES=3

# ── TOConline ─────────────────────────────────────────────────────────────────
TOCONLINE_BASE_URL=https://api11.toconline.pt
TOCONLINE_CLIENT_ID=your_client_id
TOCONLINE_CLIENT_SECRET=your_client_secret
TOCONLINE_AUTHORIZATION_CODE=
TOCONLINE_REFRESH_TOKEN=
